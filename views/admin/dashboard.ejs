<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            margin-bottom: 2rem;
            background: var(--card-bg);
            border-radius: var(--radius-lg);
            overflow: hidden;
            box-shadow: var(--shadow-soft);
            border: 1px solid var(--glass-border);
        }
        th, td {
            padding: 1.25rem 1rem;
            text-align: left;
            border-bottom: 1px solid var(--border-color);
        }
        th {
            background: var(--bg-color);
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.85rem;
            letter-spacing: 1px;
            color: var(--text-color);
        }
        tr:last-child td { border-bottom: none; }
        .table-row-hover:hover { background: rgba(0,0,0,0.02); }
    </style>
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="container fade-in">
        <%- include('../partials/flash') %>
        
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;" class="stagger-1">
            <h1 style="font-size: 2.5rem;">Admin Dashboard</h1>
            <a href="/admin/add-package" class="btn">Add New Package</a>
        </div>

        <!-- Metric Analytics Calculation -->
        <% 
            let totalRevenue = 0;
            let totalBookings = bookings.length;
            bookings.forEach(b => { if(b.paymentStatus === 'Paid') totalRevenue += b.totalPrice; });
            let activePackages = packages.length;
        %>

        <!-- Metric UI Grid -->
        <div class="metric-grid stagger-1">
            <div class="metric-card">
                <div class="metric-title">Total Revenue</div>
                <div class="metric-value">₹<%= totalRevenue.toLocaleString('en-IN') %></div>
            </div>
            <div class="metric-card" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%);">
                <div class="metric-title">Total Bookings</div>
                <div class="metric-value"><%= totalBookings %></div>
            </div>
            <div class="metric-card" style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);">
                <div class="metric-title">Active Packages</div>
                <div class="metric-value"><%= activePackages %></div>
            </div>
        </div>

        <!-- Manage Packages -->
        <div class="stagger-2">
            <h2 style="margin-bottom: 1.5rem;">Manage Packages</h2>
            <div style="overflow-x: auto;">
                <table>
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Price</th>
                            <th>Total Seats</th>
                            <th>Available Seats</th>
                            <th>Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (packages.length === 0) { %>
                            <tr>
                                <td colspan="6" style="text-align: center;">No packages found.</td>
                            </tr>
                        <% } else { %>
                            <% packages.forEach(pkg => { %>
                                <tr class="table-row-hover">
                                    <td style="font-weight: 600;"><%= pkg.title %></td>
                                    <td style="color: var(--primary-color);">₹<%= pkg.price.toLocaleString('en-IN') %></td>
                                    <td><%= pkg.totalSeats %></td>
                                    <td>
                                        <% if (pkg.availableSeats === 0) { %>
                                            <span style="font-weight: bold; color: var(--seat-booked);"><%= pkg.availableSeats %></span>
                                        <% } else { %>
                                            <span style="font-weight: bold; color: inherit;"><%= pkg.availableSeats %></span>
                                        <% } %>
                                    </td>
                                    <td><%= new Date(pkg.date).toLocaleDateString() %></td>
                                    <td>
                                        <form action="/admin/delete/<%= pkg._id %>" method="POST" style="display: inline-block;">
                                            <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this package?');" style="padding: 0.5rem 1rem; border-radius: 8px;">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- System Bookings -->
        <div class="stagger-3 mt-4">
            <h2 style="margin-bottom: 1.5rem;">Recent Bookings</h2>
            <div style="overflow-x: auto;">
                <table>
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Package</th>
                            <th>Seats</th>
                            <th>Total Price</th>
                            <th>Status</th>
                            <th>Booking Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (bookings.length === 0) { %>
                            <tr>
                                <td colspan="6" style="text-align: center;">No bookings found.</td>
                            </tr>
                        <% } else { %>
                            <% bookings.forEach(booking => { %>
                                <tr class="table-row-hover">
                                    <td><strong style="color: var(--heading-color);"><%= booking.userId ? booking.userId.name : 'Unknown User' %></strong></td>
                                    <td><%= booking.packageId ? booking.packageId.title : 'Deleted Package' %></td>
                                    <td><%= booking.selectedSeats.join(', ') %></td>
                                    <td style="color: var(--primary-color); font-weight: 600;">₹<%= booking.totalPrice.toLocaleString('en-IN') %></td>
                                    <td>
                                        <% if (booking.paymentStatus === 'Paid') { %>
                                            <span style="background: rgba(16, 185, 129, 0.1); color: var(--seat-selected); padding: 0.3rem 0.8rem; border-radius: 20px; font-weight: 600; font-size: 0.85rem;"><%= booking.paymentStatus %></span>
                                        <% } else { %>
                                            <span style="background: rgba(245, 158, 11, 0.1); color: #f59e0b; padding: 0.3rem 0.8rem; border-radius: 20px; font-weight: 600; font-size: 0.85rem;"><%= booking.paymentStatus %></span>
                                        <% } %>
                                    </td>
                                    <td style="opacity: 0.8; font-size: 0.9rem;"><%= new Date(booking.bookingDate).toLocaleDateString() %></td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

    </div>

    <%- include('../partials/footer') %>
    <script src="/js/themeToggle.js"></script>
</body>
</html>
