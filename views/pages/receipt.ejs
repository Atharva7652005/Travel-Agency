<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .receipt-card {
            max-width: 600px;
            margin: 2rem auto;
            border: 2px dashed var(--border-color);
            background: var(--card-bg);
            padding: 3rem;
            position: relative;
        }
        .receipt-header {
            text-align: center;
            border-bottom: 2px solid var(--border-color);
            padding-bottom: 1.5rem;
            margin-bottom: 1.5rem;
        }
        .receipt-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 1rem;
            font-size: 1.1rem;
        }
        .paid-stamp {
            position: absolute;
            top: 2rem;
            right: 2rem;
            color: var(--seat-selected);
            border: 4px solid var(--seat-selected);
            font-weight: bold;
            font-size: 1.5rem;
            padding: 0.5rem 1rem;
            transform: rotate(15deg);
            opacity: 0.8;
            border-radius: 0.5rem;
        }
        @media print {
            .navbar, .footer, .btn, .theme-toggle { display: none !important; }
            body { background: white !important; color: black !important; }
            .receipt-card { border: none !important; box-shadow: none !important; }
        }
    </style>
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="container">
        <div class="receipt-card fade-in">
            <div class="paid-stamp">PAID</div>
            
            <div class="receipt-header">
                <h2>Travel Agency Booking Receipt</h2>
                <p>Transaction ID: #<%= booking._id %></p>
            </div>
            
            <div class="receipt-row">
                <span><strong>Passenger:</strong></span>
                <span><%= booking.userId ? booking.userId.name : 'Unknown Passenger' %></span>
            </div>
            
            <div class="receipt-row">
                <span><strong>Travel Package:</strong></span>
                <span><%= booking.packageId.title %></span>
            </div>
            
            <div class="receipt-row">
                <span><strong>Travel Date:</strong></span>
                <span><%= new Date(booking.packageId.date).toLocaleDateString() %></span>
            </div>

            <div class="receipt-row">
                <span><strong>Booking Date:</strong></span>
                <span><%= new Date(booking.bookingDate).toLocaleDateString() %></span>
            </div>

            <div class="receipt-row">
                <span><strong>Seats Booked (<%= booking.selectedSeats.length %>):</strong></span>
                <span><%= booking.selectedSeats.join(', ') %></span>
            </div>

            <hr style="border: 0; border-top: 2px solid var(--border-color); margin: 2rem 0;">

            <div class="receipt-row" style="font-size: 1.5rem; font-weight: bold; color: var(--primary-color);">
                <span>Total Paid:</span>
                <span>₹<%= booking.totalPrice.toLocaleString('en-IN') %></span>
            </div>
            
            <div class="text-center mt-4">
                <button onclick="window.print()" class="btn" style="margin-right: 1rem;">🖨️ Print Receipt</button>
                <a href="/my-bookings" class="btn" style="background-color: var(--seat-available); color: var(--heading-color) !important;">Back to Bookings</a>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>
    <script src="/js/themeToggle.js"></script>
</body>
</html>
