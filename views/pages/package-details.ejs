<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="container">
        <%- include('../partials/flash') %>

        <div class="card" style="margin-top: 2rem;">
            <img src="<%= travelPackage.image %>" alt="<%= travelPackage.title %>" style="height: 400px;">
            <div class="card-body">
                <h2><%= travelPackage.title %></h2>
                <p style="font-size: 1.1rem; margin: 1rem 0;"><%= travelPackage.description %></p>
                
                <div style="display: flex; gap: 2rem; margin-bottom: 1.5rem; flex-wrap: wrap;">
                    <p><strong>Price:</strong> ₹<%= travelPackage.price.toLocaleString('en-IN') %></p>
                    <p><strong>Total Seats:</strong> <%= travelPackage.totalSeats %></p>
                    <p><strong>Available Seats:</strong> <%= travelPackage.availableSeats %></p>
                    <p><strong>Date:</strong> <%= new Date(travelPackage.date).toLocaleDateString() %></p>
                </div>

                <hr style="border: 0; border-top: 1px solid var(--border-color); margin: 2rem 0;">

                <!-- Booking Form -->
                <form action="/book/<%= travelPackage._id %>" method="POST" id="booking-form">
                    <input type="hidden" name="selectedSeats" id="selected-seats">
                    
                    <h3 class="text-center mt-3 mb-2">Select Your Seats</h3>
                    
                    <div class="seat-map-wrapper fade-in" id="seat-map" data-total="<%= travelPackage.totalSeats %>" data-taken="<%= takenSeats %>" data-price="<%= travelPackage.price %>">
                        <div class="screen-indicator">TOUR START / STAGE</div>
                        <!-- seats injected via seatSelection.js -->
                    </div>

                    <div class="legend mb-3 text-center">
                        <div class="legend-item"><div class="legend-color" style="background-color: var(--seat-available);"></div> Available</div>
                        <div class="legend-item"><div class="legend-color" style="background-color: var(--seat-selected); box-shadow: 0 0 10px rgba(16,185,129,0.5);"></div> Selected</div>
                        <div class="legend-item"><div class="legend-color" style="background-color: var(--seat-booked);"></div> Booked</div>
                    </div>

                    <div style="text-align: center; margin-top: 1.5rem;">
                        <h4 style="font-size: 1.25rem;">Total Amount: <span id="total-price" style="display:inline-block; transition: all 0.2s;">₹0</span></h4>
                    </div>

                    <div class="text-center mt-4">
                        <button type="submit" class="btn" id="book-btn" disabled style="width: 100%; max-width: 400px; padding: 1rem; font-size: 1.2rem;">Proceed to Payment</button>
                    </div>
                </form>

            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>
    <script src="/js/themeToggle.js"></script>
    <script src="/js/seatSelection.js"></script>
</body>
</html>
