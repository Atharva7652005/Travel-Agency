<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .checkout-wrapper {
            max-width: 900px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 1.2fr 1fr;
            gap: 3rem;
            align-items: start;
        }

        .order-summary {
            background: var(--primary-gradient);
            padding: 2.5rem;
            border-radius: var(--radius-lg);
            color: white;
            box-shadow: var(--shadow-hover);
        }

        .order-summary p { color: rgba(255,255,255,0.9); }
        .order-summary h3 { color: white; margin-bottom: 0.5rem; }

        .payment-form-container {
            background: var(--card-bg);
            padding: 2.5rem;
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-soft);
            border: 1px solid var(--glass-border);
        }

        .stripe-card-mock {
            width: 100%;
            height: 180px;
            background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
            border-radius: 12px;
            padding: 1.5rem;
            color: white;
            margin-bottom: 2rem;
            position: relative;
            box-shadow: 0 10px 20px rgba(0,0,0,0.15);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .card-chip {
            width: 40px; height: 25px;
            background: linear-gradient(135deg, #fcd34d 0%, #fbbf24 100%);
            border-radius: 4px;
        }

        .card-mock-number { font-size: 1.25rem; letter-spacing: 2px; font-family: monospace; }
        .card-mock-name { text-transform: uppercase; font-size: 0.85rem; opacity: 0.8;}
        
        .cc-row { display: flex; gap: 1rem; }
        .cc-row > div { flex: 1; }

        @media (max-width: 768px) {
            .checkout-wrapper { grid-template-columns: 1fr; }
        }

        .success-checkmark {
            width: 80px; height: 80px;
            border-radius: 50%;
            display: block; margin: 0 auto;
            text-align: center; line-height: 80px; font-size: 2.5rem;
            background: var(--seat-selected); color: white;
            animation: bounceIn 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        }

        @keyframes bounceIn {
            0% { transform: scale(0); }
            50% { transform: scale(1.2); }
            100% { transform: scale(1); }
        }

    </style>
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="container fade-in">
        <div class="checkout-wrapper">
            <!-- Left Side: Summary -->
            <div class="order-summary stagger-1">
                <h2 style="color: white; margin-bottom: 2rem;">Order Summary</h2>
                
                <h3 style="font-size: 1.5rem;"><%= booking.packageId.title %></h3>
                <p class="mb-3">Travel Date: <%= new Date(booking.packageId.date).toLocaleDateString() %></p>
                
                <hr style="border: 0; border-top: 1px dashed rgba(255,255,255,0.4); margin-bottom: 1.5rem;">
                
                <div style="display: flex; justify-content: space-between; margin-bottom: 1rem;">
                    <span>Tickets (<%= booking.selectedSeats.length %>)</span>
                    <span>Seats: <%= booking.selectedSeats.join(', ') %></span>
                </div>
                
                <hr style="border: 0; border-top: 1px dashed rgba(255,255,255,0.4); margin: 1.5rem 0;">

                <div style="display: flex; justify-content: space-between; font-size: 1.5rem; font-weight: 700;">
                    <span>Total</span>
                    <span>₹<%= booking.totalPrice.toLocaleString('en-IN') %></span>
                </div>
            </div>

            <!-- Right Side: Payment Form -->
            <div class="payment-form-container stagger-2">
                <h3 class="mb-3">Payment Details</h3>

                <div class="stripe-card-mock" id="mock-preview">
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <div class="card-chip"></div>
                        <h4 style="color: white; opacity: 0.5;">VISA</h4>
                    </div>
                    <div>
                        <div class="card-mock-number" id="mock-num">**** **** **** ****</div>
                        <div style="display: flex; justify-content: space-between; margin-top: 0.5rem;">
                            <div class="card-mock-name" id="mock-name">YOUR NAME</div>
                            <div class="card-mock-name" id="mock-exp">MM/YY</div>
                        </div>
                    </div>
                </div>

                <form id="payment-form">
                    <div class="form-group-floating">
                        <input type="text" id="cardName" class="form-control" placeholder="John Doe" required>
                        <label for="cardName">Cardholder Name</label>
                    </div>
                    
                    <div class="form-group-floating">
                        <input type="text" id="cardNum" class="form-control payment-card-input" placeholder="4242 4242 4242 4242" maxlength="19" required>
                        <label for="cardNum">Card Number</label>
                    </div>

                    <div class="cc-row">
                        <div class="form-group-floating">
                            <input type="text" id="expiry" class="form-control" placeholder="12/26" maxlength="5" required>
                            <label for="expiry">Expiry</label>
                        </div>
                        <div class="form-group-floating">
                            <input type="password" id="cvv" class="form-control" placeholder="123" maxlength="3" required>
                            <label for="cvv">CVV</label>
                        </div>
                    </div>

                    <button type="submit" id="pay-btn" class="btn mt-2" style="width: 100%; font-size: 1.1rem; padding: 1.25rem;">
                        Pay ₹<%= booking.totalPrice.toLocaleString('en-IN') %>
                    </button>
                    <p class="text-center mt-3" style="font-size: 0.8rem; font-weight: 600; color: var(--seat-selected);">
                        🔒 Secured by 256-bit encryption
                    </p>
                </form>
            </div>
        </div>
    </div>

    <!-- Success Modal -->
    <div class="modal-overlay" id="success-modal">
        <div class="modal" id="modal-box">
            <!-- Render loader initially, toggle to success graphic via JS -->
            <div id="loader-view">
                <div class="loader-spinner"></div>
                <h3>Processing Payment...</h3>
                <p style="opacity: 0.7; margin-top: 0.5rem;">Please do not close this window.</p>
            </div>

            <div id="success-view" style="display: none;">
                <div class="success-checkmark mb-3">✓</div>
                <h2 style="color: var(--heading-color); margin-bottom: 1rem;">Payment Successful!</h2>
                <p class="mb-3">Your transaction has been securely processed.</p>
                <p class="mb-4 text-center" style="opacity: 0.7; font-size: 0.9rem;">Navigating to your digital boarding pass...</p>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>
    <script src="/js/themeToggle.js"></script>
    <script>
        // Mock Card Sync UI
        document.getElementById('cardName').addEventListener('input', e => {
            document.getElementById('mock-name').textContent = e.target.value.toUpperCase() || 'YOUR NAME';
        });
        document.getElementById('cardNum').addEventListener('input', e => {
            let val = e.target.value.replace(/\D/g, '').replace(/(.{4})/g, '$1 ').trim();
            e.target.value = val;
            document.getElementById('mock-num').textContent = val || '**** **** **** ****';
        });
        document.getElementById('expiry').addEventListener('input', e => {
            let val = e.target.value.replace(/\D/g, '').replace(/(.{2})/, '$1/').trim().substr(0, 5);
            e.target.value = val;
            document.getElementById('mock-exp').textContent = val || 'MM/YY';
        });

        // Form Submit
        document.getElementById('payment-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            // Show Overlay & Loader
            const modalOverlay = document.getElementById('success-modal');
            modalOverlay.style.display = 'flex';
            
            // Give 10ms for display flex to apply before animating active transform
            setTimeout(() => { document.getElementById('modal-box').classList.add('active'); }, 10);

            // Execute backend call securely
            let fetchSuccess = false;
            let targetRedirect = '/my-bookings';

            try {
                const response = await fetch('/confirm-payment/<%= booking._id %>', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                const data = await response.json();
                if (data.success) {
                    fetchSuccess = true;
                    targetRedirect = data.redirectUrl;
                }
            } catch (err) {
                console.error(err);
            }

            // Simulate UX loading wait 2.5 seconds deliberately to feel premium
            setTimeout(() => {
                if (fetchSuccess) {
                    // Switch UI
                    document.getElementById('loader-view').style.display = 'none';
                    document.getElementById('success-view').style.display = 'block';
                    
                    // Trigger CSS Confetti DOM injection
                    createConfetti();

                    // Wait 2.5s on screen then redirect
                    setTimeout(() => {
                        window.location.href = targetRedirect;
                    }, 2500);

                } else {
                    alert('Payment failed or seats are no longer available!');
                    modalOverlay.style.display = 'none';
                    document.getElementById('modal-box').classList.remove('active');
                }
            }, 2500);
        });

        // Minimal CSS Confetti Generator function
        function createConfetti() {
            const colors = ['#fbcfe8', '#fce7f3', '#10b981', '#3b82f6', '#fcd34d', '#8b5cf6'];
            for(let i = 0; i < 40; i++) {
                const conf = document.createElement('div');
                conf.classList.add('confetti');
                conf.style.left = Math.random() * 100 + 'vw';
                conf.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
                conf.style.animationDuration = (Math.random() * 2 + 2) + 's';
                conf.style.animationDelay = (Math.random() * 1) + 's';
                document.body.appendChild(conf);
            }
        }
    </script>
</body>
</html>
