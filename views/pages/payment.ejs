<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .cc-form { display: flex; flex-direction: column; gap: 1rem; }
        .cc-row { display: flex; gap: 1rem; }
        .cc-row > div { flex: 1; }
    </style>
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="container" style="max-width: 600px;">
        <div class="card fade-in">
            <div class="card-body">
                <h2 class="text-center mb-3">Complete Your Payment</h2>
                
                <div style="background: var(--bg-color); padding: 1.5rem; border-radius: 0.5rem; margin-bottom: 2rem; border: 1px dashed var(--border-color);">
                    <p><strong>Package:</strong> <%= booking.packageId.title %></p>
                    <p><strong>Selected Seats:</strong> <%= booking.selectedSeats.join(', ') %> (<%= booking.selectedSeats.length %> tickets)</p>
                    <h3 class="mt-2" style="color: var(--primary-color);">Total Amount: ₹<%= booking.totalPrice.toLocaleString('en-IN') %></h3>
                </div>

                <form id="payment-form" class="cc-form">
                    <div class="form-group">
                        <label for="cardName">Name on Card</label>
                        <input type="text" id="cardName" class="form-control" placeholder="John Doe" required>
                    </div>
                    
                    <div class="form-group">
                        <label for="cardNum">Card Number</label>
                        <input type="text" id="cardNum" class="form-control payment-card-input" placeholder="0000 0000 0000 0000" maxlength="19" required>
                    </div>

                    <div class="cc-row">
                        <div class="form-group">
                            <label for="expiry">Expiry (MM/YY)</label>
                            <input type="text" id="expiry" class="form-control" placeholder="12/28" maxlength="5" required>
                        </div>
                        <div class="form-group">
                            <label for="cvv">CVV</label>
                            <input type="password" id="cvv" class="form-control" placeholder="***" maxlength="3" required>
                        </div>
                    </div>

                    <button type="submit" id="pay-btn" class="btn mt-2" style="width: 100%; font-size: 1.1rem; padding: 1rem;">
                        Pay ₹<%= booking.totalPrice.toLocaleString('en-IN') %> Securely
                    </button>
                    <p class="text-center mt-2" style="font-size: 0.85rem; opacity: 0.7;">This is a secure 256-bit encrypted connection.</p>
                </form>
            </div>
        </div>
    </div>

    <!-- Success Modal -->
    <div class="modal-overlay" id="success-modal">
        <div class="modal">
            <h1 style="font-size: 3rem; margin-bottom: 1rem;">🎉</h1>
            <h2 style="color: var(--seat-selected); margin-bottom: 1rem;">Payment Successful!</h2>
            <p class="mb-3">Your booking for <strong><%= booking.packageId.title %></strong> has been confirmed securely.</p>
            <p class="mb-4">You will be redirected automatically to your receipt...</p>
        </div>
    </div>

    <%- include('../partials/footer') %>
    <script src="/js/themeToggle.js"></script>
    <script>
        document.getElementById('payment-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('pay-btn');
            btn.textContent = 'Processing...';
            btn.disabled = true;

            try {
                const response = await fetch('/confirm-payment/<%= booking._id %>', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                const data = await response.json();
                
                if (data.success) {
                    document.getElementById('success-modal').style.display = 'flex';
                    setTimeout(() => {
                        window.location.href = data.redirectUrl;
                    }, 2500); // 2.5 second delay out of courtesy so they read the success modal
                } else {
                    alert(data.message || 'Payment failed');
                    btn.textContent = 'Try Again';
                    btn.disabled = false;
                }
            } catch (err) {
                alert('Network error occurred.');
                btn.textContent = 'Try Again';
                btn.disabled = false;
            }
        });
        
        // Very basic simple input mask formatting for demo CC
        document.getElementById('cardNum').addEventListener('input', function (e) {
            this.value = this.value.replace(/\D/g, '').replace(/(.{4})/g, '$1 ').trim();
        });
        document.getElementById('expiry').addEventListener('input', function (e) {
            this.value = this.value.replace(/\D/g, '').replace(/(.{2})/, '$1/').trim().substr(0, 5);
        });
    </script>
</body>
</html>
