<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="icon" type="image/x-icon" href="https://images.unsplash.com/photo-1436491865332-7a61a109cc05?w=50&h=50&fit=crop&q=80">
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="container" style="max-width: 400px;">
        <%- include('../partials/flash') %>
        <div class="card">
            <div class="card-body">
                <h2 style="text-align: center; margin-bottom: 1.5rem;">Login</h2>
                <form action="/login" method="POST">
                    <div class="form-group">
                        <label for="email">Email</label>
                        <input type="email" id="email" name="email" class="form-control" placeholder="Enter your email address" required>
                    </div>
                    <div class="form-group">
                        <label for="password">Password</label>
                        <input type="password" id="password" name="password" class="form-control" placeholder="Enter your password" required>
                    </div>
                    <button type="submit" class="btn" style="width: 100%;">Login</button>
                    <p style="text-align: center; margin-top: 1rem;">
                        Don't have an account? <a href="/signup" style="color: var(--primary-color);">Sign Up</a>
                    </p>
                </form>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>
    <script src="/js/themeToggle.js"></script>
</body>
</html>
